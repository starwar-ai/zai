generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentStatus {
  DRAFT
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

enum DataScope {
  ALL
  DEPARTMENT
  PERSONAL
}

enum DeclarationNameMappingStatus {
  PENDING
  GENERATING
  APPROVED
  REVIEW_REQUIRED
  REJECTED
  FAILED
}

enum DeclarationNameJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum DeclarationNameJobItemStatus {
  PENDING
  SUCCESS
  FAILED
}

model Document {
  id               String         @id @default(uuid()) @db.Uuid
  typeId           String         @map("type_id") @db.VarChar(64)
  code             String         @unique @db.VarChar(64)
  status           DocumentStatus @default(DRAFT)
  masterData       Json           @map("master_data") @db.JsonB
  detailTables     Json           @map("detail_tables") @db.JsonB
  searchText       String         @default("") @map("search_text")
  sourceDocumentId String?        @map("source_document_id") @db.Uuid
  sourceTypeId     String?        @map("source_type_id") @db.VarChar(64)
  sourceCode       String?        @map("source_code") @db.VarChar(64)
  createdBy        String         @map("created_by") @db.VarChar(100)
  createdById      String         @map("created_by_id") @db.VarChar(64)
  departmentId     String?        @map("department_id") @db.VarChar(64)
  version          Int            @default(1)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  source     Document?        @relation("DocumentTrace", fields: [sourceDocumentId], references: [id], onDelete: Restrict)
  downstream Document[]       @relation("DocumentTrace")
  activities ActivityRecord[]

  @@unique([sourceDocumentId, typeId])
  @@index([typeId, status])
  @@index([updatedAt])
  @@index([typeId, updatedAt])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin, map: "documents_search_text_trgm_idx")
  @@index([masterData(ops: JsonbPathOps)], type: Gin, map: "documents_master_data_gin_idx")
  @@index([detailTables(ops: JsonbPathOps)], type: Gin, map: "documents_detail_tables_gin_idx")
  @@map("documents")
}

model DataPermissionPolicy {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.VarChar(64)
  typeId             String    @map("type_id") @db.VarChar(64)
  scope              DataScope @default(PERSONAL)
  extraDepartmentIds String[]  @default([]) @map("extra_department_ids")
  extraUserIds       String[]  @default([]) @map("extra_user_ids")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([userId, typeId])
  @@index([userId])
  @@map("data_permission_policies")
}

model UserPreference {
  userId    String   @id @map("user_id") @db.VarChar(64)
  settings  Json     @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("user_preferences")
}

model UserNotification {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.VarChar(64)
  title      String    @db.VarChar(120)
  content    String    @db.VarChar(500)
  level      String    @default("info") @db.VarChar(20)
  target     Json?     @db.JsonB
  readAt     DateTime? @map("read_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([userId, readAt, createdAt])
  @@map("user_notifications")
}

model SystemMenu {
  id             String   @id @db.VarChar(80)
  groupId        String   @map("group_id") @db.VarChar(64)
  groupLabel     String   @map("group_label") @db.VarChar(80)
  label          String   @db.VarChar(80)
  icon           String   @default("FileText") @db.VarChar(60)
  target         String   @db.VarChar(40)
  targetId       String?  @map("target_id") @db.VarChar(80)
  permissionCode String?  @map("permission_code") @db.VarChar(100)
  order          Int      @default(0)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([groupId, order])
  @@map("system_menus")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  code        String     @unique @db.VarChar(64)
  name        String     @db.VarChar(80)
  description String?    @db.VarChar(300)
  permissions String[]   @default([])
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  users       UserRole[]

  @@map("roles")
}

model AppUser {
  id             String     @id @db.VarChar(64)
  name           String     @db.VarChar(80)
  email          String?    @db.VarChar(160)
  departmentId   String?    @map("department_id") @db.VarChar(64)
  departmentName String?    @map("department_name") @db.VarChar(100)
  status         String     @default("ACTIVE") @db.VarChar(20)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  roles          UserRole[]

  @@index([status])
  @@map("app_users")
}

model UserRole {
  userId   String @map("user_id") @db.VarChar(64)
  roleId   String @map("role_id") @db.Uuid
  user     AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model ActivityRecord {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  action     String   @db.VarChar(40)
  operator   String   @db.VarChar(100)
  message    String   @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@map("activity_records")
}

model DocumentSequence {
  typeId    String   @map("type_id") @db.VarChar(64)
  period    String   @db.Char(6)
  value     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([typeId, period])
  @@map("document_sequences")
}

model DeclarationNameMapping {
  id                            String                       @id @default(uuid()) @db.Uuid
  normalizedName                String                       @map("normalized_name") @db.VarChar(255)
  normalizedNameEng             String                       @map("normalized_name_eng") @db.VarChar(255)
  rawName                       String                       @map("raw_name") @db.VarChar(255)
  rawNameEng                    String                       @map("raw_name_eng") @db.VarChar(255)
  rowCount                      Int                          @default(0) @map("row_count")
  existingDeclarationVariants  String?                      @map("existing_declaration_variants")
  existingEngVariants          String?                      @map("existing_eng_variants")
  declarationName               String?                      @map("declaration_name") @db.VarChar(100)
  customsDeclarationNameEng     String?                      @map("customs_declaration_name_eng") @db.VarChar(100)
  confidence                    Decimal?                     @db.Decimal(4, 3)
  reviewRequired                Boolean                      @default(true) @map("review_required")
  reviewReason                  String?                      @map("review_reason") @db.VarChar(500)
  status                        DeclarationNameMappingStatus @default(PENDING)
  source                        String                       @default("api") @db.VarChar(50)
  promptVersion                 String?                      @map("prompt_version") @db.VarChar(50)
  modelVersion                  String?                      @map("model_version") @db.VarChar(100)
  approvedBy                    String?                      @map("approved_by") @db.VarChar(100)
  approvedAt                    DateTime?                    @map("approved_at") @db.Timestamptz(3)
  rejectedBy                    String?                      @map("rejected_by") @db.VarChar(100)
  rejectedAt                    DateTime?                    @map("rejected_at") @db.Timestamptz(3)
  rejectReason                  String?                      @map("reject_reason") @db.VarChar(500)
  errorMessage                  String?                      @map("error_message")
  createdAt                     DateTime                     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                     DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(3)
  jobItems                      DeclarationNameGenerationJobItem[]
  audits                        DeclarationNameAuditLog[]
  sourceItems                   DeclarationNameSourceItem[]

  @@unique([normalizedName, normalizedNameEng])
  @@index([status, updatedAt])
  @@index([reviewRequired, status])
  @@map("declaration_name_mappings")
}

model DeclarationNameGenerationJob {
  id            String                   @id @default(uuid()) @db.Uuid
  status        DeclarationNameJobStatus @default(PENDING)
  inputCount    Int                      @default(0) @map("input_count")
  successCount  Int                      @default(0) @map("success_count")
  failedCount   Int                      @default(0) @map("failed_count")
  reviewCount   Int                      @default(0) @map("review_count")
  errorMessage  String?                  @map("error_message")
  createdBy     String                   @map("created_by") @db.VarChar(64)
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  startedAt     DateTime?                @map("started_at") @db.Timestamptz(3)
  finishedAt    DateTime?                @map("finished_at") @db.Timestamptz(3)
  updatedAt     DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  items         DeclarationNameGenerationJobItem[]

  @@index([createdBy, createdAt])
  @@map("declaration_name_generation_jobs")
}

model DeclarationNameGenerationJobItem {
  id            String                           @id @default(uuid()) @db.Uuid
  jobId         String                           @map("job_id") @db.Uuid
  mappingId     String                           @map("mapping_id") @db.Uuid
  status        DeclarationNameJobItemStatus     @default(PENDING)
  errorMessage  String?                          @map("error_message")
  createdAt     DateTime                         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(3)
  job           DeclarationNameGenerationJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  mapping       DeclarationNameMapping           @relation(fields: [mappingId], references: [id], onDelete: Restrict)

  @@unique([jobId, mappingId])
  @@index([jobId, status])
  @@map("declaration_name_generation_job_items")
}

model DeclarationNameSourceItem {
  id                        String                  @id @default(uuid()) @db.Uuid
  sourceType                String                  @map("source_type") @db.VarChar(30)
  sourceItemId              String                  @map("source_item_id") @db.VarChar(100)
  rawName                   String                  @map("raw_name") @db.VarChar(255)
  rawNameEng                String                  @map("raw_name_eng") @db.VarChar(255)
  normalizedName            String                  @map("normalized_name") @db.VarChar(255)
  normalizedNameEng         String                  @map("normalized_name_eng") @db.VarChar(255)
  declarationName           String?                 @map("declaration_name") @db.VarChar(100)
  customsDeclarationNameEng String?                 @map("customs_declaration_name_eng") @db.VarChar(100)
  mappingId                 String?                 @map("mapping_id") @db.Uuid
  locked                    Boolean                 @default(false)
  updatedAt                 DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)
  mapping                   DeclarationNameMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceItemId])
  @@index([normalizedName, normalizedNameEng])
  @@map("declaration_name_source_items")
}

model DeclarationNameAuditLog {
  id         String                  @id @default(uuid()) @db.Uuid
  mappingId  String?                 @map("mapping_id") @db.Uuid
  action     String                  @db.VarChar(50)
  actor      String                  @db.VarChar(100)
  beforeJson Json?                   @map("before_json") @db.JsonB
  afterJson  Json?                   @map("after_json") @db.JsonB
  note       String?                 @db.VarChar(500)
  createdAt  DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  mapping    DeclarationNameMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)

  @@index([mappingId, createdAt])
  @@map("declaration_name_audit_logs")
}
