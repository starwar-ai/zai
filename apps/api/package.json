{
  "name": "@zform/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "declaration:import": "tsx src/scripts/import-declaration-name-template.ts",
    "declaration:batch": "tsx src/scripts/build-declaration-name-batch.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@zform/shared": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.20.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^5.22.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
